# Copy this to .env

# --- Scraper / general ---
DISCORD_TOKEN=
# Discord scraper: bot token + admin-configured default guild IDs.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=
# Application (client) ID of the MTG Cal bot — used to build the "Add to Discord" invite URL for
# users connecting their own private servers. Distinct from AUTH_DISCORD_ID (the login OAuth app).
# Find it at https://discord.com/developers/applications → your bot app → General Information.
DISCORD_BOT_CLIENT_ID=
# Ed25519 public key for verifying Discord HTTP Interactions (slash commands).
# Find it at the Developer Portal → your bot app → General Information → "Public Key".
# Required for /api/discord/interactions to accept signed requests from Discord.
DISCORD_BOT_PUBLIC_KEY=
# Optional — when set, `npm run discord:register` registers commands in this
# guild only (instant propagation; useful for testing). Unset = global.
DISCORD_REGISTER_GUILD_ID=
# Shared secret for the Discord subscription dispatcher cron endpoint.
# Set via Railway Cron: curl -X POST $URL/api/discord/dispatch -H "x-dispatch-secret: $DISPATCH_SECRET"
DISPATCH_SECRET=
# Shared secret for the off-Railway DB backup endpoint. Consumed by
# .github/workflows/backup.yml — also store the same value in the repo's
# Actions secrets as BACKUP_SECRET. Generate: `openssl rand -hex 32`.
BACKUP_SECRET=
ANTHROPIC_API_KEY=

# --- Legacy admin password login (break-glass) ---
SESSION_SECRET=
ADMIN_PASSWORD_HASH=

# --- Auth.js (NextAuth v5) ---
# openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Comma-separated emails auto-promoted to admin role on first OAuth signin.
ADMIN_EMAILS=

# Discord OAuth (https://discord.com/developers)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend magic-link email (https://resend.com)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PlayIRL <noreply@playirl.gg>"

# --- Venue / event image cascade (Google Maps Platform) ---
# Google Cloud "browser" key — exposed client-side. Powers two surfaces:
#   1. The interactive Maps Embed iframe on event detail pages
#      (app/event/[id]/page.tsx). Requires the "Maps Embed API".
#   2. The static-map fallback in the event-card image cascade
#      (lib/event-image.ts). Requires the "Maps Static API".
# Lock the key down with HTTP referrer restrictions in the Google Cloud
# Console (allow your prod + dev origins).
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Google Cloud server-side key — never sent to the browser. Used for:
#   1. Real venue photos via Places API (New) "places:searchText" + photo
#      (lib/venue-image-fetcher.ts tier 2).
#   2. Venue images via Street View Static API (lib/venue-image-fetcher.ts tier 3).
#   3. Forward geocoding via the Geocoding API (lib/geocode.ts) — used at
#      scrape time and by cli/backfill-event-coords.ts. Falls back to OSM
#      Nominatim when unset.
# Enable on the key: Places API (New), Street View Static API, Geocoding API.
# Lock down with IP restrictions (your Railway egress IPs) in the Google
# Cloud Console.
GOOGLE_PLACES_API_KEY=
