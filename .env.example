# Copy this to .env

# --- Scraper / general ---
DISCORD_TOKEN=
# Discord scraper: bot token + admin-configured default guild IDs.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=
# Application (client) ID of the MTG Cal bot — used to build the "Add to Discord" invite URL for
# users connecting their own private servers. Distinct from AUTH_DISCORD_ID (the login OAuth app).
# Find it at https://discord.com/developers/applications → your bot app → General Information.
DISCORD_BOT_CLIENT_ID=
ANTHROPIC_API_KEY=

# --- Legacy admin password login (break-glass) ---
SESSION_SECRET=
ADMIN_PASSWORD_HASH=

# --- Auth.js (NextAuth v5) ---
# openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Comma-separated emails auto-promoted to admin role on first OAuth signin.
ADMIN_EMAILS=

# Discord OAuth (https://discord.com/developers)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend magic-link email (https://resend.com)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PlayIRL <noreply@playirl.gg>"

# --- Venue / event image cascade ---
# Mapbox public access token (pk.*) — used for two things, both safe to expose
# in client-side URLs:
#   1. Render-time static map images on event cards (lib/event-image.ts).
#   2. Forward-geocoding in cli/backfill-event-coords.ts.
# Lock the token down with URL referrer restrictions in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Cloud API key with the Places API (New) and Street View Static API
# enabled. Used SERVER-SIDE ONLY by lib/venue-image-fetcher.ts to download a
# real venue photo when one is available. Optional — without it, the fetcher
# falls back to scraping og:image from the venue's own site, and render-time
# falls back to a Mapbox map.
GOOGLE_PLACES_API_KEY=
