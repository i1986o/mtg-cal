# Copy this to .env

# --- Scraper / general ---
DISCORD_TOKEN=
# Discord scraper: bot token + admin-configured default guild IDs.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=
# Application (client) ID of the MTG Cal bot — used to build the "Add to Discord" invite URL for
# users connecting their own private servers. Distinct from AUTH_DISCORD_ID (the login OAuth app).
# Find it at https://discord.com/developers/applications → your bot app → General Information.
DISCORD_BOT_CLIENT_ID=
ANTHROPIC_API_KEY=

# --- Legacy admin password login (break-glass) ---
SESSION_SECRET=
ADMIN_PASSWORD_HASH=

# --- Auth.js (NextAuth v5) ---
# openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Comma-separated emails auto-promoted to admin role on first OAuth signin.
ADMIN_EMAILS=

# Discord OAuth (https://discord.com/developers)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend magic-link email (https://resend.com)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="PlayIRL <noreply@playirl.gg>"
